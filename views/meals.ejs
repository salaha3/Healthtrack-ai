<!DOCTYPE html>
<html lang="en">
<head>
  <title>HealthTrack AI - Meal Log</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="logo">HealthTrack AI</div>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/profile">Profile</a>
      <a href="/log">Daily Activity</a>
      <a href="/meals">Meal Log</a>
      <a href="/recommended">Recommended</a>

    </div>
  </nav>

  <main class="container">
    <header class="page-header">
      <h1>Meal Log</h1>
      <p>Log meals and track calories and macros.</p>
    </header>

    <form action="/meals" method="POST" class="form-box">
      <label>Date</label>
      <input type="date" name="meal_date" required>

      <label>Meal Type</label>
      <select name="meal_type" required>
        <option value="Breakfast">Breakfast</option>
        <option value="Lunch">Lunch</option>
        <option value="Dinner">Dinner</option>
        <option value="Snack">Snack</option>
      </select>

      <label>Meal Name</label>
      <input type="text" name="meal_name" placeholder="e.g. Chicken wrap" required>

      <label>Calories</label>
      <input type="number" name="calories" required>

      <label>Protein (g)</label>
      <input type="number" name="protein" required>

      <label>Carbs (g)</label>
      <input type="number" name="carbs" required>

      <label>Fats (g)</label>
      <input type="number" name="fats" required>

      <button type="submit">Save Meal</button>
    </form>

    <section class="history-box">
      <h2>Recent Meals</h2>
      <table class="history-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Type</th>
            <th>Meal</th>
            <th>Calories</th>
            <th>Protein</th>
            <th>Carbs</th>
            <th>Fats</th>
          </tr>
        </thead>
        <tbody>
          <% if (meals && meals.length > 0) { %>
            <% meals.forEach(meal => { %>
              <tr>
                <td><%= new Date(meal.meal_date).toISOString().split('T')[0] %></td>
                <td><%= meal.meal_type %></td>
                <td><%= meal.meal_name %></td>
                <td><%= meal.calories %></td>
                <td><%= meal.protein %> g</td>
                <td><%= meal.carbs %> g</td>
                <td><%= meal.fats %> g</td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="7">No meals logged yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </section>
  </main>
</body>
<html>