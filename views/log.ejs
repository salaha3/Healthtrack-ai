<!DOCTYPE html>
<html>
<head>
  <title>HealthTrack AI - Daily Activity Log</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="logo">HealthTrack AI</div>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/profile">Profile</a>
      <a href="/log">Daily Activity</a>
      <a href="/meals">Meal Log</a>
    </div>
  </nav>

  <main class="container">
    <header class="page-header">
      <h1>Daily Activity Log</h1>
      <p>Enter your daily steps, sleep, and weight.</p>
    </header>

    <form action="/log" method="POST" class="form-box">
      <label>Date</label>
      <input type="date" name="log_date" required>

      <label>Steps</label>
      <input type="number" name="steps" required>

      <label>Sleep Hours</label>
      <input type="number" step="0.1" name="sleep_hours" required>

      <label>Current Weight (kg)</label>
      <input type="number" step="0.1" name="weight_kg" required>

      <button type="submit">Save Activity Log</button>
    </form>

    <section class="history-box">
      <h2>Recent Activity Logs</h2>
      <table class="history-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Steps</th>
            <th>Sleep</th>
            <th>Weight</th>
          </tr>
        </thead>
        <tbody>
          <% if (logs && logs.length > 0) { %>
            <% logs.forEach(log => { %>
              <tr>
                <td><%= new Date(log.log_date).toISOString().split('T')[0] %></td>
                <td><%= log.steps %></td>
                <td><%= log.sleep_hours %> hrs</td>
                <td><%= log.weight_kg %> kg</td>
              </tr>
            <% }) %>
          <% } else { %>
            <tr>
              <td colspan="4">No activity logs yet.</td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>