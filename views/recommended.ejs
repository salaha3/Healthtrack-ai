<!DOCTYPE html>
<html>
<head>
  <title>Recommended</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav class="navbar">
    <div class="logo">HealthTrack AI</div>
    <div class="nav-links">
      <a href="/">Dashboard</a>
      <a href="/profile">Profile</a>
      <a href="/log">Daily Activity</a>
      <a href="/meals">Meal Log</a>
      <a href="/recommended">Recommended</a>
    </div>
  </nav>

  <main class="container">
  <h1>Recommended Page</h1>

  <% if (user) { %>
    <p>This is the recommended for <strong><%= user.name %></strong> page.</p>
  <% } else { %>
    <p>This is the recommended for you page.</p>
  <% } %>

  <section class="card-container">
  <div class="card">
    <h3>Recommended Sleep</h3>
    <p>8 hours</p>
  </div>

  <div class="card">
    <h3>Recommended Steps</h3>
    <p><%= user ? user.step_goal : 0 %> steps</p>
  </div>

  <div class="card">
    <h3>Recommended Calories</h3>
    <p><%= user ? user.target_calories : 0 %> kcal</p>
  </div>
</section>
</main>

<% 
  const avgSteps = activityData && activityData.length
    ? Math.round(activityData.reduce((sum, item) => sum + item.steps, 0) / activityData.length)
    : 0;
%>

<% 
  const dailyMealTotals = {};
  if (mealData) {
    mealData.forEach(meal => {
      const date = new Date(meal.meal_date).toISOString().split('T')[0];
      if (!dailyMealTotals[date]) {
        dailyMealTotals[date] = 0;
      }
      dailyMealTotals[date] += meal.calories;
    });
  }

  const calorieDays = Object.keys(dailyMealTotals).length;
  const avgCalories = calorieDays
    ? Math.round(Object.values(dailyMealTotals).reduce((sum, value) => sum + value, 0) / calorieDays)
    : 0;
%>

<section class="goal-box">
  <h3>Step Recommendation</h3>

  <p><strong>Your Average Steps:</strong> <%= avgSteps %></p>

  <% if (user) { %>
    <% const stepDifference = user.step_goal - avgSteps; %>

    <% if (stepDifference <= 0) { %>
      <p>Well done, you are right on track with your steps.</p>
    <% } else if (stepDifference <= 1000) { %>
      <p>You only need <%= stepDifference %> more steps. Why not walk to the off license store or take a short walk outside?</p>
    <% } else if (stepDifference <= 3000) { %>
      <p>You need <%= stepDifference %> more steps. A walk after work or after dinner could help you reach your goal.</p>
    <% } else { %>
      <p>You are <%= stepDifference %> steps below your goal. Try adding some treadmill or cardio machine time at the gym.</p>
    <% } %>
  <% } %>
</section>

<section class="goal-box">
  <h3>Calorie Recommendation</h3>

  <p><strong>Your Average Calories:</strong> <%= avgCalories %> kcal</p>

  <% if (user) { %>
    <% const calorieDifference = avgCalories - user.target_calories; %>
    
    <% if (calorieDifference <= 0) { %>
      <p>Well done, your calorie intake is within your target range.</p>
    <% } else if (calorieDifference <= 200) { %>
      <p>You are only <%= calorieDifference %> kcal above your target. A small adjustment like reducing snacks could help.</p>
    <% } else if (calorieDifference <= 500) { %>
      <p>You are <%= calorieDifference %> kcal above your target. Try choosing lighter meals or reducing portion sizes.</p>
    <% } else { %>
      <p>You are <%= calorieDifference %> kcal above your target. Consider planning your meals ahead or avoiding high-calorie foods.</p>
    <% } %>
  <% } %>
</section>